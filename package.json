{
  "name": "chassisnotes-graph-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "serve:ssr:chassisnotes-graph-ui": "node dist/chassisnotes-graph-ui/server/server.mjs",
    "preview": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "biome check .",
    "format": "biome format --write .",
    "lint:ci": "biome ci"
  },
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.1",
    "@ngrx/signals": "^21.0.1",
    "dexie": "^4.3.0",
    "ng-diagram": "^1.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@biomejs/biome": "2.4.7",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20.17.19",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wrangler": "^4.73.0",
    "xhr2": "^0.2.1"
  }
}
